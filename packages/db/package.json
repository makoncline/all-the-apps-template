{
  "name": "@hello/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@hello/contracts": "workspace:*",
    "@hello/core": "workspace:*",
    "@libsql/client": "^0.15.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.41.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test drizzle.config.ts --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio"
