{
  "name": "@hello/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NEXT_PUBLIC_SERVER_BASE_URL=${NEXT_PUBLIC_SERVER_BASE_URL:-http://localhost:3001} next dev --port 3000",
    "build": "NEXT_PUBLIC_SERVER_BASE_URL=${NEXT_PUBLIC_SERVER_BASE_URL:-http://localhost:3001} next build",
    "start": "next start --port 3000",
    "lint": "eslint src next.config.ts --ext .ts,.tsx",
    "typecheck": "next typegen && tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hello/sdk": "workspace:*",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.68.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^15.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "~19.0.10",
    "@types/react-dom": "~19.0.4",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.2.1"
  }
}
