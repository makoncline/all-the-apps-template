{
  "name": "@hello/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "./index.ts",
  "scripts": {
    "dev": "APP_VARIANT=development expo run:ios",
    "dev:device": "APP_VARIANT=development expo run:ios --device",
    "dev:lan": "APP_VARIANT=development expo start --dev-client --lan --clear",
    "preview": "APP_VARIANT=preview expo prebuild --clean --platform ios && APP_VARIANT=preview expo run:ios --configuration Release --no-bundler",
    "preview:device": "APP_VARIANT=preview expo prebuild --clean --platform ios && APP_VARIANT=preview expo run:ios --device --configuration Release --no-bundler",
    "ota:preview": "APP_VARIANT=preview eas update --channel preview",
    "prebuild:ios": "APP_VARIANT=development expo prebuild --platform ios",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src index.ts --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "android": "expo run:android",
    "ios": "APP_VARIANT=development expo run:ios",
    "ios:device": "APP_VARIANT=development expo run:ios --device",
    "preview:update": "APP_VARIANT=preview eas update --channel preview"
  },
  "dependencies": {
    "@hello/sdk": "workspace:*",
    "@rn-primitives/slot": "^1.2.0",
    "@tanstack/react-query": "^5.68.0",
    "babel-preset-expo": "~54.0.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-dev-client": "~6.0.20",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "nativewind": "^4.1.23",
    "react": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "0.2.2",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "5.6.2",
    "react-native-worklets": "^0.5.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@expo/config": "^55.0.8",
    "@types/react": "~19.1.17",
    "eas-cli": "^18.2.0",
    "tailwindcss": "^3.4.17"
  }
}
